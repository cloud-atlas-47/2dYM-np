Cell[CellGroupData[{

Cell["5. Z_n^top rules and pre-calculation", "Section",
 CellChangeTimes->{3.9812493440812397`*^9, 
  3.981249478257422*^9},ExpressionUUID->"4416f2c5-224c-412d-9062-\
0dfc25e228eb"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"A", "[", "f_", "]"}], " ", ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"d", "[", "f", "]"}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "/", "24"}], ")"}], "*", 
         RowBox[{"E2", "[", "\[Tau]", "]"}], "*", "f"}]}], ")"}], "//", 
      "Cancel"}], "//", "Expand"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Denote", " ", "the", " ", "operator", " ", "D_", 
    RowBox[{"{", 
     RowBox[{"-", "1"}], "}"}], " ", "as", " ", "A", " ", "for", " ", 
    "simplicity"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"B", "[", "g_", "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"d", "[", "g", "]"}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "/", "8"}], ")"}], "*", 
         RowBox[{"E2", "[", "\[Tau]", "]"}], "*", "g"}]}], ")"}], "//", 
      "Cancel"}], "//", "Expand"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "Denote", " ", "the", " ", "operator", " ", "D_", "3", " ", "as", " ", "B",
     " ", "for", " ", "simplicity"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Zpre", " ", "=", " ", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", 
    RowBox[{"i", "\[LessEqual]", 
     RowBox[{"G", "+", "1"}]}], ",", 
    RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Zpre", "=", 
      RowBox[{"Append", "[", 
       RowBox[{"Zpre", ",", "0"}], "]"}]}], ";"}]}], "\[IndentingNewLine]", 
   "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Zpre", "[", 
    RowBox[{"[", "1", "]"}], "]"}], "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"n", "=", "1"}], ",", 
   RowBox[{"n", "\[LessEqual]", "G"}], ",", 
   RowBox[{"n", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"start", " ", "=", " ", 
     RowBox[{"AbsoluteTime", "[", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Zpre", "[", 
      RowBox[{"[", 
       RowBox[{"n", "+", "1"}], "]"}], "]"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"hpre", "[", 
          RowBox[{"[", "n", "]"}], "]"}], "-", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "/", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"2", "*", "m"}], ")"}], "!"}], ")"}]}], ")"}], "*", 
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Binomial", "[", 
                RowBox[{
                 RowBox[{"2", "*", "m"}], ",", "k"}], "]"}], "*", 
               RowBox[{"Nest", "[", 
                RowBox[{"A", ",", 
                 RowBox[{"Zpre", "[", 
                  RowBox[{"[", 
                   RowBox[{"n", "-", "m", "+", "1"}], "]"}], "]"}], ",", 
                 "k"}], "]"}], "*", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"1", "/", "3"}], ")"}], "^", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"2", "*", "m"}], "-", "k"}], ")"}]}], ")"}], "*", 
               RowBox[{"(", 
                RowBox[{"2", "^", "m"}], ")"}], "*", 
               RowBox[{"Nest", "[", 
                RowBox[{"B", ",", "1", ",", 
                 RowBox[{
                  RowBox[{"3", "*", "m"}], "-", "k"}]}], "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"k", ",", "0", ",", 
                RowBox[{"2", "*", "m"}]}], "}"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"m", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ")"}], "//", 
       "Cancel"}], "//", "Expand"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"end", "=", 
     RowBox[{"AbsoluteTime", "[", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Zpre \>\"", ",", "n", ",", "\"\< time length = \>\"", ",", 
      RowBox[{"end", "-", "start"}]}], "]"}], ";"}]}], "\[IndentingNewLine]", 
  "]"}]}], "Input",
