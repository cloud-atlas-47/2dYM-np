Cell[CellGroupData[{

Cell["3. higher weight Eisenstein series recursion", "Section",
 CellChangeTimes->{{3.981249333153871*^9, 
  3.981249338674264*^9}},ExpressionUUID->"9085ce79-cb87-4b37-9a02-\
2055e82fa0ca"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"BernoulliB2k", "[", "k_", "]"}], ":=", 
    RowBox[{"BernoulliB", "[", 
     RowBox[{"2", "k"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"E2k", "[", "1", "]"}], "=", 
     RowBox[{"E2", "[", "\[Tau]", "]"}]}], ";", "\n", 
    RowBox[{
     RowBox[{"E2k", "[", "2", "]"}], "=", 
     RowBox[{"E4", "[", "\[Tau]", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"E2k", "[", "3", "]"}], "=", 
     RowBox[{"E6", "[", "\[Tau]", "]"}]}], ";"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Clear", "[", "E2k", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"E2k", "[", 
     RowBox[{"k_", "/;", 
      RowBox[{"k", "\[GreaterEqual]", "1"}]}], "]"}], ":=", 
    RowBox[{
     RowBox[{"E2k", "[", "k", "]"}], "=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"coeff", ",", "sum", ",", "p", ",", "q"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Which", "[", 
        RowBox[{
         RowBox[{"k", "==", "1"}], ",", 
         RowBox[{"E2", "[", "\[Tau]", "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"k", "==", "2"}], ",", 
         RowBox[{"E4", "[", "\[Tau]", "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"k", "==", "3"}], ",", 
         RowBox[{"E6", "[", "\[Tau]", "]"}], ",", "\[IndentingNewLine]", 
         "True", ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"coeff", "=", 
           RowBox[{"3", "/", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"3", "-", "k"}], ")"}], 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"4", 
                 RowBox[{"k", "^", "2"}]}], "-", "1"}], ")"}]}], ")"}]}]}], ";", 
          RowBox[{"sum", "=", 
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"p", "\[LessEqual]", "q"}], ",", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"2", "p"}], "-", "1"}], ")"}], 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"2", "q"}], "-", "1"}], ")"}], "*", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"BernoulliB2k", "[", "p", "]"}], "/", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"2", "p"}], ")"}], "!"}]}], ")"}], "*", 
                RowBox[{"E2k", "[", "p", "]"}], "*", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"BernoulliB2k", "[", "q", "]"}], "/", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"2", "q"}], ")"}], "!"}]}], ")"}], "*", 
                RowBox[{"E2k", "[", "q", "]"}], "*", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"p", "\[Equal]", "q"}], ",", "1", ",", "2"}], 
                 "]"}]}], ",", "0"}], "]"}], "\[IndentingNewLine]", ",", 
             RowBox[{"{", 
              RowBox[{"p", ",", "2", ",", 
               RowBox[{"Floor", "[", 
                RowBox[{"k", "/", "2"}], "]"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"q", ",", 
               RowBox[{"Max", "[", 
                RowBox[{"p", ",", 
                 RowBox[{"k", "-", "p"}]}], "]"}], ",", 
               RowBox[{"k", "-", "p"}]}], "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"expr", "=", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"sum", "*", "coeff", "*", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"2", "k"}], ")"}], "!"}]}], ")"}], "/", 
            RowBox[{"BernoulliB2k", "[", "k", "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"ExpandAll", "[", "expr", "]"}], "//", "Together"}], "//",
            "Factor"}]}]}], "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"E2kpre", " ", "=", " ", 
     RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "\[LessEqual]", 
        RowBox[{"G", "+", "1"}]}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"E2kpre", " ", "=", " ", 
         RowBox[{"Append", "[", 
          RowBox[{"E2kpre", ",", "0"}], "]"}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "\[LessEqual]", 
        RowBox[{"G", "+", "1"}]}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"E2kpre", "[", 
          RowBox[{"[", "i", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"E2k", "[", "i", "]"}], "//", "Cancel"}], "//", 
          "Expand"}]}], ";"}]}], "\[IndentingNewLine]", "]"}]}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"E2kpre", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"E2k", "[", "i", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{"G", "+", "1"}]}], "}"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.981249331260573*^9, 3.981249332589658*^9}, {
   3.981249514643531*^9, 3.981249643320784*^9}, 3.981418120097125*^9},
 CellLabel->
  "In[287]:=",ExpressionUUID->"5bf9c5b4-e0a6-445b-925b-dfe11f03dc11"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. h_n^top rules and pre-calculation", "Section",
 CellChangeTimes->{{3.981249326604435*^9, 3.981249341302342*^9}, 
   3.981249649974924*^9},ExpressionUUID->"178aeeb8-081e-4e40-88a2-\
77763d3caef5"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"epre", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"hpre", " ", "=", " ", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", "1"}], ",", 
   RowBox[{"i", "\[LessEqual]", "G"}], ",", 
   RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"epre", "=", 
     RowBox[{"Append", "[", 
      RowBox[{"epre", ",", "0"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"hpre", "=", 
     RowBox[{"Append", "[", 
      RowBox[{"hpre", ",", "0"}], "]"}]}], ";"}]}], "\[IndentingNewLine]", 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ee", "[", "l_", "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"BernoulliB", "[", 
        RowBox[{
         RowBox[{"2", "*", "l"}], "+", "2"}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", "*", "l"}], "+", "2"}], ")"}]}], ")"}], " ", "*", 
     RowBox[{"(", 
      RowBox[{"2", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "2"}], "*", "l"}], ")"}]}], ")"}], "*", 
     RowBox[{"Nest", "[", 
      RowBox[{"d", ",", 
       RowBox[{"E2kpre", "[", 
        RowBox[{"[", 
         RowBox[{"l", "+", "1"}], "]"}], "]"}], ",", 
       RowBox[{
        RowBox[{"2", "*", "l"}], "-", "1"}]}], "]"}]}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"e_l", ",", " ", "3.15"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"i", "=", "1"}], ",", 
     RowBox[{"i", "\[LessEqual]", "G"}], ",", 
     RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"start", " ", "=", " ", 
       RowBox[{"AbsoluteTime", "[", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"epre", "[", 
        RowBox[{"[", "i", "]"}], "]"}], "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"ee", "[", "i", "]"}], "//", "Cancel"}], "//", "Expand"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"end", "=", 
       RowBox[{"AbsoluteTime", "[", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<epre \>\"", ",", "i", ",", "\"\< time length = \>\"", ",", 
        RowBox[{"end", "-", "start"}]}], "]"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", 
    RowBox[{"i", "\[LessEqual]", "G"}], ",", 
    RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"start", " ", "=", " ", 
      RowBox[{"AbsoluteTime", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"hnexpansion", " ", "=", " ", "i"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"hpre", "[", 
       RowBox[{"[", "i", "]"}], "]"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{"SeriesCoefficient", "[", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"x", "^", 
               RowBox[{"(", 
                RowBox[{"2", "*", "l"}], ")"}]}], "*", 
              RowBox[{
               RowBox[{"e", "[", "l", "]"}], "/", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"2", "*", "l"}], ")"}], "!"}], ")"}]}]}], ",", 
             RowBox[{"{", 
              RowBox[{"l", ",", "1", ",", "hnexpansion"}], " ", "}"}]}], 
            "]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "0", ",", 
            RowBox[{"2", "*", "i"}]}], "}"}]}], "]"}], "//", "Cancel"}], "//",
        "Expand"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"end", "=", 
      RowBox[{"AbsoluteTime", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<hpre \>\"", ",", "i", ",", "\"\< time length = \>\"", ",", 
       RowBox[{"end", "-", "start"}]}], "]"}], ";"}]}], "\[IndentingNewLine]",
    "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", 
    RowBox[{"i", "\[LessEqual]", "G"}], ",", 
    RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"start", " ", "=", " ", 
      RowBox[{"AbsoluteTime", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"hpre", "[", 
       RowBox[{"[", "i", "]"}], "]"}], " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"hpre", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "/.", 
         RowBox[{
          RowBox[{"e", "[", "l_", "]"}], ":>", 
          RowBox[{"epre", "[", 
           RowBox[{"[", "l", "]"}], "]"}]}]}], "//", "Cancel"}], "//", 
       "Expand"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"end", "=", 
      RowBox[{"AbsoluteTime", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<hpre alter \>\"", ",", "i", ",", "\"\< time length = \>\"",
        ",", 
       RowBox[{"end", "-", "start"}]}], "]"}], ";"}]}], "\[IndentingNewLine]",
    "]"}], ";"}]}], "Input",
