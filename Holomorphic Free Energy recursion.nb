Cell[CellGroupData[{

Cell["2. Eisenstein series rules", "Section",
 CellChangeTimes->{{3.981249277017229*^9, 
  3.9812492806193247`*^9}},ExpressionUUID->"544bc4d4-530e-4559-ae46-\
6fe966905049"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"E2", "[", "\[Tau]", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"E4", "[", "\[Tau]", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"E6", "[", "\[Tau]", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"Et", "[", "\[Tau]", "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"relation", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"E2", "[", "\[Tau]", "]"}], ",", "\[Tau]"}], "]"}], "\[Rule]", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"E2", "[", "\[Tau]", "]"}], "^", "2"}], "-", 
           RowBox[{"E4", "[", "\[Tau]", "]"}]}], ")"}], "/", "12"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"E4", "[", "\[Tau]", "]"}], ",", "\[Tau]"}], "]"}], "\[Rule]", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"E2", "[", "\[Tau]", "]"}], "*", 
            RowBox[{"E4", "[", "\[Tau]", "]"}]}], "-", 
           RowBox[{"E6", "[", "\[Tau]", "]"}]}], ")"}], "/", "3"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"E6", "[", "\[Tau]", "]"}], ",", "\[Tau]"}], "]"}], "\[Rule]", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"E2", "[", "\[Tau]", "]"}], "*", 
            RowBox[{"E6", "[", "\[Tau]", "]"}]}], "-", 
           RowBox[{
            RowBox[{"E4", "[", "\[Tau]", "]"}], "^", "2"}]}], ")"}], "/", 
         "2"}]}]}], 
      RowBox[{"(*", 
       RowBox[{",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"Et", "[", "\[Tau]", "]"}], ",", "\[Tau]"}], "]"}], "\[Rule]",
          " ", 
         RowBox[{
          RowBox[{"Et", "[", "\[Tau]", "]"}], "*", 
          RowBox[{
           RowBox[{"E2", "[", "\[Tau]", "]"}], "/", "24"}]}]}]}], "*)"}], 
      "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"d", "[", "f_", "]"}], ":=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{"f", ",", "\[Tau]"}], "]"}], "/.", "relation"}], 
      RowBox[{"(*", 
       RowBox[{"//", "Cancel"}], "*)"}], "//", "Expand"}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.981249274748949*^9, 3.981249282453718*^9}, {
