Cell["1. Eisenstein series rules", "Section",
 CellChangeTimes->{{3.981418471742138*^9, 
  3.981418477510705*^9}},ExpressionUUID->"deac6b1c-07a9-4a76-abe8-\
926d9647f18a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"E2", "[", "\[Tau]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"E4", "[", "\[Tau]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"E6", "[", "\[Tau]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Et", "[", "\[Tau]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"S", "[", "\[Tau]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"relation", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"E2", "[", "\[Tau]", "]"}], ",", "\[Tau]"}], "]"}], "\[Rule]", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"E2", "[", "\[Tau]", "]"}], "^", "2"}], "-", 
         RowBox[{"E4", "[", "\[Tau]", "]"}]}], ")"}], "/", "12"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"E4", "[", "\[Tau]", "]"}], ",", "\[Tau]"}], "]"}], "\[Rule]", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"E2", "[", "\[Tau]", "]"}], "*", 
          RowBox[{"E4", "[", "\[Tau]", "]"}]}], "-", 
         RowBox[{"E6", "[", "\[Tau]", "]"}]}], ")"}], "/", "3"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"E6", "[", "\[Tau]", "]"}], ",", "\[Tau]"}], "]"}], "\[Rule]", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"E2", "[", "\[Tau]", "]"}], "*", 
          RowBox[{"E6", "[", "\[Tau]", "]"}]}], "-", 
         RowBox[{
          RowBox[{"E4", "[", "\[Tau]", "]"}], "^", "2"}]}], ")"}], "/", 
       "2"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"Et", "[", "\[Tau]", "]"}], ",", "\[Tau]"}], "]"}], "\[Rule]",
       " ", 
      RowBox[{
       RowBox[{"Et", "[", "\[Tau]", "]"}], "*", 
       RowBox[{
        RowBox[{"E2", "[", "\[Tau]", "]"}], "/", "24"}]}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"S", "[", "\[Tau]", "]"}], ",", "\[Tau]"}], "]"}], "\[Rule]", 
      " ", 
      RowBox[{
       RowBox[{"S", "[", "\[Tau]", "]"}], "^", "2"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"d", "[", "f_", "]"}], ":=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"f", ",", "\[Tau]"}], "]"}], "/.", "relation"}], "//", 
     "Cancel"}], "//", "Expand"}]}], ";"}]}], "Input",
 CellLabel->
  "In[159]:=",ExpressionUUID->"b9c665fe-9010-444c-a131-3e750fdfc5a1"]
}, Open  ]],

