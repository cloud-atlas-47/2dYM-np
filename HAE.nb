Cell[CellGroupData[{

Cell["3. Calculation of nonholomorphic Free energies", "Section",
 CellChangeTimes->{{3.981418514564457*^9, 
  3.981418523888142*^9}},ExpressionUUID->"2e5f573e-5086-481a-b95c-\
e1c4832b6794"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"nonholF", " ", "=", " ", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nonholF", " ", "=", " ", 
   RowBox[{"Append", "[", 
    RowBox[{"nonholF", ",", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "2"}], ")"}], "*", 
       RowBox[{"Log", "[", 
        RowBox[{"2", "*", "Pi", "*", 
         RowBox[{"S", "[", "\[Tau]", "]"}]}], "]"}]}], "-", 
      RowBox[{"Log", "[", 
       RowBox[{"Et", "[", "\[Tau]", "]"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SUM", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"SetSharedVariable", "[", "SUM", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"For", " ", "[", 
  RowBox[{
   RowBox[{"i", "=", "2"}], ",", 
   RowBox[{"i", "\[LessEqual]", 
    RowBox[{"Length", "[", "holF", "]"}]}], ",", 
   RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"start", " ", "=", " ", 
     RowBox[{"AbsoluteTime", "[", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"SUM", " ", "=", " ", "0"}], ";", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"ParallelDo", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"SUM", " ", "+=", " ", 
          RowBox[{
           RowBox[{"d", "[", 
            RowBox[{"nonholF", "[", 
             RowBox[{"[", "h", "]"}], "]"}], "]"}], "*", 
           RowBox[{"d", "[", 
            RowBox[{"nonholF", "[", 
             RowBox[{"[", 
              RowBox[{"i", "-", "h"}], "]"}], "]"}], "]"}]}]}], "//", 
         "Cancel"}], "//", "Expand"}], ";"}], "\[IndentingNewLine]", ",", 
      RowBox[{"{", 
       RowBox[{"h", ",", 
        RowBox[{"i", "-", "1"}]}], "}"}]}], "]"}], ";", "\[IndentingNewLine]",
     "\[IndentingNewLine]", 
    RowBox[{"FISRT", " ", "=", 
     RowBox[{
      RowBox[{"d", "[", 
       RowBox[{"d", "[", 
        RowBox[{"nonholF", "[", 
         RowBox[{"[", 
          RowBox[{"i", "-", "1"}], "]"}], "]"}], "]"}], "]"}], "+", 
      RowBox[{
       RowBox[{"S", "[", "\[Tau]", "]"}], "*", 
       RowBox[{"d", "[", 
        RowBox[{"nonholF", "[", 
         RowBox[{"[", 
          RowBox[{"i", "-", "1"}], "]"}], "]"}], "]"}]}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"LHS", " ", "=", " ", 
     RowBox[{"FISRT", "+", "SUM"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"TEMP", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "2"}], ")"}], "*", 
       RowBox[{"Integrate", "[", 
        RowBox[{"LHS", ",", 
         RowBox[{"S", "[", "\[Tau]", "]"}]}], "]"}]}], "+", 
      RowBox[{"holF", "[", 
       RowBox[{"[", "i", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"nonholF", " ", "=", " ", 
     RowBox[{"Append", "[", 
      RowBox[{"nonholF", ",", 
       RowBox[{
        RowBox[{"TEMP", "//", "Cancel"}], "//", "Expand"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"end", " ", "=", " ", 
     RowBox[{"AbsoluteTime", "[", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"i", ",", "\"\< time = \>\"", ",", 
      RowBox[{"end", "-", "start"}], ",", "\"\<[s]\>\""}], "]"}], ";"}]}], 
  "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.95110475630229*^9, 3.951104820033295*^9}, {
   3.951104860872943*^9, 3.951104861555642*^9}, {3.951104901233429*^9, 
   3.9511049392378387`*^9}, {3.951104987058618*^9, 3.9511049872688446`*^9}, {
   3.951105065327859*^9, 3.9511050742027392`*^9}, {3.951105544875325*^9, 
