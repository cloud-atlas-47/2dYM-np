  3.981423788655736*^9}},ExpressionUUID->"9ae1111c-e450-4b59-bdfa-\
6b8ae2e83a15"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"A", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"\"\<holoutput60.dat\>\"", ",", "\"\<List\>\""}], "]"}]}], 
    ";"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
