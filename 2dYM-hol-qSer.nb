Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"order", "=", "100"}], 
  RowBox[{"(*", 
   RowBox[{"1000", ";"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"order", " ", "of", " ", "q"}], "-", "series"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"$isensteinseriespower", ",", "$isensteinseries"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$isensteinseries", "[", 
    RowBox[{"z_", ",", "q_", ",", "k_"}], "]"}], ":=", 
   RowBox[{"1", "-", 
    RowBox[{"4", 
     RowBox[{"k", "/", 
      RowBox[{"BernoulliB", "[", 
       RowBox[{"2", "k"}], "]"}]}], 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"m", "^", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", "k"}], "-", "1"}], ")"}]}], 
          RowBox[{"q", "^", "d"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"m", ",", 
           RowBox[{"Divisors", "[", "d", "]"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"d", ",", "1", ",", "order"}], "}"}]}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"E2s", "=", 
   RowBox[{"Series", "[", 
    RowBox[{
     RowBox[{"$isensteinseries", "[", 
      RowBox[{"z", ",", "q", ",", "1"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"q", ",", "0", ",", "order"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"Dm1", ",", "D3"}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9557539868322277`*^9, 3.955754019396821*^9}, {
   3.981442961872985*^9, 3.981442964736362*^9}, 3.981443124721662*^9, {
   3.9814441504803667`*^9, 3.981444159171896*^9}, {3.981444328887162*^9, 
   3.981444330939612*^9}, {3.981444380529237*^9, 3.981444382458795*^9}},
 CellLabel->
  "In[140]:=",ExpressionUUID->"0c811238-8e37-4ee4-bb3f-733d8b0fad7a"],

