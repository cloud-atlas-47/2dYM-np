Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"maxn", "=", "10"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"200", ";"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{"maximum", " ", "genus"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"count", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"Dynamic", "[", "count", "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Clear", "[", "$isensteinseriespower", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$isensteinseriespower", "[", 
    RowBox[{"z_", ",", "q_", ",", "k_", ",", "ddd_", ",", "power_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"$isensteinseriespower", "[", 
     RowBox[{"z", ",", "q", ",", "k", ",", "ddd", ",", "power"}], "]"}], "=", 
    
    RowBox[{
     RowBox[{"Series", "[", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"m", "^", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"2", "k"}], "-", "1"}], ")"}]}], 
             RowBox[{"d", "^", "ddd"}], " ", 
             RowBox[{"q", "^", "d"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"m", ",", 
              RowBox[{"Divisors", "[", "d", "]"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"d", ",", "1", ",", 
            RowBox[{"order", "-", "power"}]}], "}"}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"q", ",", "0", ",", 
         RowBox[{"order", "-", "power"}]}], "}"}]}], "]"}], "^", 
     "power"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"count", "++"}], ";", 
     RowBox[{"$isensteinseriespower", "[", 
      RowBox[{"z", ",", "q", ",", 
       RowBox[{"l", "+", "1"}], ",", 
       RowBox[{
        RowBox[{"2", "l"}], "-", "1"}], ",", "1"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"l", ",", "1", ",", "maxn"}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"hn3int", "[", "0", "]"}], "=", 
   RowBox[{"1", "/", "2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"count2", "=", 
      RowBox[{"Length", "[", 
       RowBox[{"cllist", "[", "$n", "]"}], "]"}]}], ";"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Print", "[", 
      RowBox[{
       RowBox[{"DateString", "[", "]"}], ",", "\"\< $n = \>\"", ",", "$n"}], 
      "]"}], ";", 
     RowBox[{
      RowBox[{"hn3int", "[", "$n", "]"}], "=", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Binomial", "[", 
            RowBox[{
             RowBox[{"2", "$n"}], ",", 
             RowBox[{"2", "l"}]}], "]"}], "2", 
           RowBox[{"l", "/", "$n"}]}], ")"}], "*", 
         RowBox[{"$isensteinseriespower", "[", 
          RowBox[{"z", ",", "q", ",", 
           RowBox[{"l", "+", "1"}], ",", 
           RowBox[{
            RowBox[{"2", "l"}], "-", "1"}], ",", "1"}], "]"}], 
         RowBox[{"hn3int", "[", 
          RowBox[{"$n", "-", "l"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"l", ",", "1", ",", "$n"}], "}"}]}], "]"}]}], ";"}], ",", 
    RowBox[{"{", 
     RowBox[{"$n", ",", "1", ",", "maxn"}], "}"}]}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9559036222619677`*^9, 3.955903691538946*^9}, {
   3.981442967011538*^9, 3.9814429694908247`*^9}, {3.981443129192569*^9, 
