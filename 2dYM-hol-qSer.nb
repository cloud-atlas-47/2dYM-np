Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Non", "-", "parallel"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"range", "=", 
     RowBox[{"{", 
      RowBox[{"0", ",", "maxn"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"count", "=", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"Dynamic", "[", "count", "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"range", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "==", "0"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"Znint2", "[", "0", "]"}], "=", 
        RowBox[{"1", "/", "2"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Znint22", "[", "0", "]"}], "=", "0"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"$nmax", "=", 
        RowBox[{"range", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Znint2", "[", "$n", "]"}], "=", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"3", "^", 
               RowBox[{"(", 
                RowBox[{"2", "$n"}], ")"}]}], 
              RowBox[{"2", "^", 
               RowBox[{"(", 
                RowBox[{"6", "$n"}], ")"}]}]}], ")"}], 
            RowBox[{"hn3int", "[", "$n", "]"}]}]}], ";", 
          RowBox[{
           RowBox[{"Znint22", "[", "$n", "]"}], "=", "0"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"$n", ",", "1", ",", "$nmax"}], "}"}]}], "]"}], ";"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"D3", "[", "k", "]"}], "=", " ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"k", "==", "0"}], ",", "1", ",", 
         RowBox[{
          RowBox[{"8", 
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"D3", "[", 
              RowBox[{"k", "-", "1"}], "]"}], ",", "q"}], "]"}], "q"}], "+", 
          RowBox[{"E2s", "*", 
           RowBox[{"D3", "[", 
            RowBox[{"k", "-", "1"}], "]"}]}]}]}], "]"}]}], " ", ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "0", ",", 
        RowBox[{"3", "*", "$nmax"}]}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{
         RowBox[{"DateString", "[", "]"}], ",", "\"\< m = \>\"", ",", "m"}], 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"ParallelEvaluate", "[", 
          RowBox[{
           RowBox[{"ClearAll", "[", "Dm1int", "]"}], ";"}], "]"}], ";"}], 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Znint2", "[", "m", "]"}], "=", 
        RowBox[{
         RowBox[{"Znint2", "[", "m", "]"}], "-", 
         RowBox[{"Znint22", "[", "m", "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Dm1int", "[", "0", "]"}], "=", 
        RowBox[{"Znint2", "[", "m", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Dm1int", "[", "k", "]"}], "=", 
          RowBox[{
           RowBox[{"24", 
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"Dm1int", "[", 
               RowBox[{"k", "-", "1"}], "]"}], ",", "q"}], "]"}], "q"}], "-", 
           
           RowBox[{"E2s", "*", 
            RowBox[{"Dm1int", "[", 
             RowBox[{"k", "-", "1"}], "]"}]}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", 
           RowBox[{
            RowBox[{"2", "$nmax"}], "-", 
            RowBox[{"2", "m"}]}]}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"count", "=", "0"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Total number:\>\"", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "2"}], "+", "m", "-", "$nmax"}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{"m", "-", "$nmax"}], ")"}]}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"table", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"count", "++"}], ";", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"Multinomial", "[", 
              RowBox[{
               RowBox[{"2", "m"}], ",", 
               RowBox[{"(", 
                RowBox[{
